# ── DevHub backend environment ─────────────────────────────────────────────
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# Server
PORT=5000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# Database — local Mongo or a free MongoDB Atlas cluster
MONGO_URI=mongodb://127.0.0.1:27017/devhub

# Auth — generate a long random string (e.g. `openssl rand -hex 32`)
JWT_SECRET=replace_me_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# AI assistant — free Llama models via Groq (https://console.groq.com/keys)
# The free tier is enough for hackathon-scale usage.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
